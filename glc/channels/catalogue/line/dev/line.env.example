# Copy this file to the glc_v1 repo root as `.env`.
#
# Example:
#   cp glc/channels/catalogue/line/dev/line.env.example .env
#
# Keep `.env` untracked. Never commit or show real LINE credentials.

# LINE demo credentials. Fill in the first two values from the LINE Developers
# Console before recording or running the live demo.
#
#   LINE_CHANNEL_ACCESS_TOKEN: Messaging API tab -> "Channel access token (long-lived)"
#   LINE_CHANNEL_SECRET:       Basic settings tab -> "Channel secret"
#
# Capture LINE_OWNER_USER_ID from a real inbound LINE message or live bridge log.
LINE_CHANNEL_ACCESS_TOKEN=replace-with-your-long-lived-channel-access-token
LINE_CHANNEL_SECRET=replace-with-your-channel-secret
LINE_OWNER_USER_ID=replace-with-real-line-source-user-id
