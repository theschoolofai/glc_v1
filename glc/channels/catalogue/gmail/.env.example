# Gmail channel adapter — required environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored; never
# commit real secrets. The adapter reads OAuth client credentials from
# the environment so no long-lived secret lives in source.

# OAuth 2.0 client (Desktop app) from Google Cloud Console.
GMAIL_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Fully-qualified Pub/Sub topic that Gmail watch() publishes to.
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications

# Optional --------------------------------------------------------------
# From address used in outbound replies (defaults to "me").
GMAIL_BOT_ADDRESS=me
# Owner email registered as owner_paired on server startup.
GLC_GMAIL_OWNER=you@gmail.com
