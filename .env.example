TWILIO_ACCOUNT_SID=AC76465ebf611798ab6345f10744cxxxxx
TWILIO_AUTH_TOKEN=d40366e2a9c43182a6a83dd9exxxxxxx
TWILIO_SANDBOX_NUMBER=whatsapp:+14155238886
TWILIO_TEST_TO=whatsapp:+917738xxxxxx
# GLC v1 WhatsApp Adapter — environment variable template
# Never put real values in this file. Never commit the real .env.

# ---------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# ---------------------------------------------------------------------------

# The numeric Phone Number ID shown on the "Step 1. Try it out" panel.
# Example: 123456789012345
WHATSAPP_PHONE_NUMBER_ID=

# Access token for the Graph API. Two options:
#   24-hour token: generated via "Generate new token" on the Step 1 panel.
#   60-day token:  exchanged via Graph API Explorer (see US1_meta_wiring_setup.md Step 10).
# Regenerate from the Step 1 panel before each demo session if using the 24-hour token.
WHATSAPP_TOKEN=

# App secret from App settings → Basic → App secret → Show.
# Used to verify X-Hub-Signature-256 on every inbound webhook (US-3).
WHATSAPP_APP_SECRET=

# Numeric App ID — visible in App settings → Basic, or in the Graph API Explorer URL.
# Used by meta_waba_subscribe_and_roundtrip.py as the app access token prefix.
WHATSAPP_APP_ID=

# WhatsApp Business Account ID — shown on the "Step 1. Try it out" panel
# as "WhatsApp Business Account ID". Used to subscribe the WABA to webhooks.
WHATSAPP_WABA_ID=

# Arbitrary string you choose — must match exactly what you enter in the
# Meta console under WhatsApp → Configuration → Webhook → Verify Token.
# Default used in docs: glc-verify-token-us1
WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# Twilio WhatsApp Sandbox
# ---------------------------------------------------------------------------

# From the Twilio Console home page.
TWILIO_ACCOUNT_SID=

# From the Twilio Console home page. Treat as a password — never log it.
TWILIO_AUTH_TOKEN=

# The shared sandbox number, e.g. +14155238886
TWILIO_SANDBOX_NUMBER=

# The exact public URL configured in Twilio Sandbox Settings as the
# "When a message comes in" webhook. Must match character-for-character
# (trailing slash, http vs https) — any mismatch breaks signature validation (US-6).
TWILIO_WEBHOOK_URL=
